# ============================================================
# PeakSSH Docker Deployment - Environment Configuration
# ============================================================
# Copy this file to .env and modify as needed.
# Credentials left empty will be auto-generated on first run.

# ---------------------
# Service Toggles
# ---------------------
# Set to "true" to enable a service, "false" to disable.
SYNC_BACKEND_ENABLED=true
PROXY_ENABLED=false
WEBAPP_ENABLED=false
MARKETPLACE_ENABLED=false

# ---------------------
# Database Configuration
# ---------------------
# Leave empty to auto-generate credentials and use internal PostgreSQL.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=peakssh
DATABASE_USER=
DATABASE_PASSWORD=

# ---------------------
# PostgreSQL (internal)
# ---------------------
POSTGRES_DB=peakssh
POSTGRES_USER=
POSTGRES_PASSWORD=

# ---------------------
# Sync Backend
# ---------------------
SYNC_BACKEND_PORT=3000
SYNC_BACKEND_IMAGE=ghcr.io/peakssh/peakssh-sync-backend:latest

# ---------------------
# Proxy (peakssh-proxy-rust)
# ---------------------
PROXY_PORT=8080
PROXY_IMAGE=ghcr.io/peakssh/peakssh-proxy-rust:latest

# ---------------------
# Webapp
# ---------------------
WEBAPP_PORT=3001
WEBAPP_IMAGE=ghcr.io/peakssh/peakssh-webapp:latest

# ---------------------
# Marketplace Backend
# ---------------------
MARKETPLACE_PORT=3002
MARKETPLACE_IMAGE=ghcr.io/peakssh/peakssh-marketplace-backend:latest

# ---------------------
# Network
# ---------------------
NETWORK_NAME=peakssh-network
